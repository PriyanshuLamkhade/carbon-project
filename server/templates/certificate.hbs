<!DOCTYPE html>
<html>
<head>
  <style>
    body {
      font-family: "Georgia", serif;
      padding: 40px;
      border: 12px double #2e7d32;
      background: #f9fff9;
      color: #1b1b1b;
    }

    .container {
      text-align: center;
      padding: 20px;
    }

    .title {
      font-size: 34px;
      font-weight: bold;
      color: #1b5e20;
      margin-bottom: 10px;
    }

    .subtitle {
      font-size: 14px;
      color: #555;
      margin-bottom: 25px;
    }

    .company {
      font-size: 26px;
      font-weight: bold;
      margin: 10px 0;
    }

    .highlight {
      font-size: 28px;
      font-weight: bold;
      color: #2e7d32;
      margin: 10px 0;
    }

    .section {
      margin-top: 25px;
      text-align: left;
      font-size: 14px;
    }

    .footer {
      margin-top: 40px;
      display: flex;
      justify-content: space-between;
      font-size: 12px;
    }

    .signature {
      text-align: center;
    }

    .line {
      margin-top: 40px;
      border-top: 1px solid black;
      width: 200px;
    }

    .watermark {
      position: absolute;
      top: 40%;
      left: 25%;
      font-size: 80px;
      color: rgba(0,0,0,0.05);
      transform: rotate(-30deg);
    }
  </style>
</head>

<body>
  <div style="text-align:center;">
    LOGO
  </div>
  <div class="watermark">CERTIFIED</div>

  <div class="container">

    <div class="title">Carbon Offset Certificate</div>
    <div class="subtitle">Verified Carbon Credit Retirement</div>

    <p>This certificate confirms that</p>

    <div class="company">{{companyName}}</div>

    <p>has successfully retired</p>

    <div class="highlight">{{tokens}} Carbon Tokens</div>

    <p>equivalent to</p>

    <div class="highlight">{{carbon}} Tons of CO₂ Offset</div>

    <div class="section">
      <p><b>Wallet Address:</b> {{wallet}}</p>
      <p><b>Transaction Hash:</b> {{txHash}}</p>
      <p><b>Certificate ID:</b> {{certificateId}}</p>
      <p><b>Date Issued:</b> {{date}}</p>
      <p><b>Retirement Reason:</b> {{reason}}</p>
    </div>

    <div class="footer">
      <div>
        <p><b>Issued By</b></p>
        <p>Carbon Registry Authority</p>
      </div>

      <div class="signature">
        <div class="line"></div>
        <p>Authorized Signature</p>
      </div>
    </div>
    
  </div>
    <div style="text-align:center; margin-top:20px;">
  <img src="{{qr}}" width="100" />
  <p style="font-size:12px;">Scan to verify</p>
</div>
</body>
</html>